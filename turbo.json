{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "test": {
      "dependsOn": [],
      "outputs": ["coverage/**"],
      "cache": true,
      "env": ["DATABASE_URL", "NODE_ENV"]
    },
    "test:e2e": {
      "dependsOn": [],
      "outputs": ["playwright-report/**", "test-results/**"],
      "cache": false,
      "env": ["E2E_BASE_URL", "E2E_SKIP_WEBSERVER", "E2E_PORT", "E2E_HAS_SEED", "CI"]
    },
    "lint": {},
    "type-check": {}
  }
}
