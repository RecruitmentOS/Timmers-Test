# =============================================================================
# Recruitment OS - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# Lines marked [required] must be set. Lines marked [optional] have safe defaults.
# Lines marked [dormant-safe] can be left empty — the feature degrades gracefully.

# =============================================================================
# Core
# =============================================================================

# [required] PostgreSQL connection string
# Docker:  postgresql://app_user:dev_password@postgres:5432/recruitment_os_dev
# Native:  postgresql://app_user:dev_password@localhost:5433/recruitment_os_dev
# Note: Use "postgres" as host inside Docker, "localhost:5433" when running natively.
DATABASE_URL=postgresql://app_user:dev_password@localhost:5433/recruitment_os_dev

# [optional] Node environment (development | production | test)
NODE_ENV=development

# =============================================================================
# Auth (Better Auth)
# =============================================================================

# [required] Secret for signing sessions. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-a-random-secret

# [required] Base URL of the API server (where Better Auth is hosted)
BETTER_AUTH_URL=http://localhost:4000

# [required] Frontend URL (for CORS and trusted origins)
FRONTEND_URL=http://localhost:3002

# =============================================================================
# File Storage (S3-compatible)
# =============================================================================
# Uses MinIO for local dev, Cloudflare R2 for production.
# Set S3_ENDPOINT for MinIO; leave unset to use R2 (requires R2_ACCOUNT_ID).

# [optional] S3-compatible endpoint URL
# Docker:  http://minio:9000
# Native:  http://localhost:9000
# Omit for Cloudflare R2 (uses R2_ACCOUNT_ID to construct endpoint)
S3_ENDPOINT=http://localhost:9000

# [optional] S3 region (default: auto)
S3_REGION=auto

# [required for file uploads] S3 access credentials
# For MinIO dev defaults: minioadmin / minioadmin
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# [required for file uploads] Bucket name
S3_BUCKET_NAME=recruitment-os

# [optional] Cloudflare R2 account ID (only needed for R2 production)
# When S3_ENDPOINT is unset, endpoint is derived as https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=

# [deprecated] Legacy R2-specific credentials (use S3_ prefixed vars instead)
# Kept for backward compatibility — S3_ vars take priority
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=

# =============================================================================
# Background Jobs (pg-boss)
# =============================================================================

# [optional] Enable background job processing (true | false)
# Set to "true" to activate pg-boss workers for reminders, notifications, etc.
JOBS_ENABLED=false

# =============================================================================
# AI - Claude (Anthropic)
# =============================================================================

# [dormant-safe] Anthropic API key for CV parsing and AI screening
# Leave empty to disable AI features (they degrade gracefully)
ANTHROPIC_API_KEY=

# =============================================================================
# Email (Resend)
# =============================================================================

# [dormant-safe] Resend API key for sending emails
# Leave empty to disable email sending (logs to console instead)
RESEND_API_KEY=

# =============================================================================
# Billing (Stripe)
# =============================================================================

# [dormant-safe] Stripe secret key for metered billing
STRIPE_SECRET_KEY=

# [dormant-safe] Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=

# [dormant-safe] Stripe price IDs for the three billing axes
STRIPE_PRICE_ACTIVE_USERS=
STRIPE_PRICE_ACTIVE_VACANCIES=
STRIPE_PRICE_PLACEMENTS=

# =============================================================================
# Calendar Integration
# =============================================================================

# [dormant-safe] Google Calendar OAuth credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# [dormant-safe] Microsoft Outlook/Azure Calendar OAuth credentials
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# =============================================================================
# Encryption
# =============================================================================

# [dormant-safe] AES-256-GCM encryption key for Meta access tokens (hex-encoded, 64 chars)
# Generate with: openssl rand -hex 32
META_ENCRYPTION_KEY=

# [dormant-safe] AES-256-GCM encryption key for calendar tokens (hex-encoded, 64 chars)
# Falls back to META_ENCRYPTION_KEY if unset
# Generate with: openssl rand -hex 32
CALENDAR_ENCRYPTION_KEY=

# =============================================================================
# External Services
# =============================================================================

# [dormant-safe] LinkedIn webhook verification secret
LINKEDIN_WEBHOOK_SECRET=

# =============================================================================
# Infrastructure (Production only)
# =============================================================================

# [production-only] Cloudflare API token for DNS/deployment
CLOUDFLARE_API_TOKEN=

# [production-only] Public API URL (used for callbacks, webhooks)
API_URL=http://localhost:4000

# =============================================================================
# Next.js (Web)
# =============================================================================

# [required] Public API URL accessible from the browser
# Must be prefixed with NEXT_PUBLIC_ to be available in client-side code
NEXT_PUBLIC_API_URL=http://localhost:4000
