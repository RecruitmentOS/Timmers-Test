FROM node:22-alpine

# Enable corepack and prepare pnpm
RUN corepack enable && corepack prepare pnpm@10 --activate

WORKDIR /app

# Copy workspace root config files
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json tsconfig.base.json turbo.json ./

# Copy package.json for each workspace package (for dependency resolution)
COPY apps/api/package.json apps/api/
COPY packages/types/package.json packages/types/
COPY packages/permissions/package.json packages/permissions/

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy source files (packages first, then app)
COPY packages/ packages/
COPY apps/api/ apps/api/

# Note: apps/api/src is volume-mounted in docker-compose for hot-reload
EXPOSE 4000

CMD ["pnpm", "--filter", "@recruitment-os/api", "dev"]
