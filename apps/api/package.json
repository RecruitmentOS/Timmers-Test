{
  "name": "@recruitment-os/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "db:push": "drizzle-kit push && psql $DATABASE_URL -f src/db/setup-rls.sql",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3",
    "@aws-sdk/s3-request-presigner": "^3",
    "@hono/node-server": "^1",
    "@hono/zod-validator": "^0.7.6",
    "@recruitment-os/permissions": "workspace:*",
    "@recruitment-os/types": "workspace:*",
    "better-auth": "^1.5",
    "dotenv": "^16",
    "drizzle-orm": "^0.45",
    "hono": "^4",
    "pg-boss": "^12.15.0",
    "postgres": "^3",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/node": "^22",
    "drizzle-kit": "^0.31",
    "tsx": "^4",
    "typescript": "^5.7"
  }
}
